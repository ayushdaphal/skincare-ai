# Environment Variables Template
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env to version control (already in .gitignore)

# Groq LLM API Key (required)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Tavily Web Search API Key (required)
# Get from: https://app.tavily.com/home
TAVILY_API_KEY=tvly_your_tavily_api_key_here

# Optional: Production Database URL (defaults to SQLite if not set)
# DATABASE_URL=postgresql://user:password@host:5432/clinikally

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: Cache TTL in seconds (default: 3600)
# CACHE_TTL=3600
